<%#
  dashboard.ejs — CRM tab main content.
  Injected into #page-content via HTMX.
  Receives: rows, total, page, limit, hygiene, counts
%>

<%- include('./top-nav', { activeTab: 'database' }) %>

<%- include('./hygiene-tabs', { counts, activeHygiene: hygiene || 'all' }) %>

<div id="action-bar">

  <!-- Legend -->
  <div style="position:relative;">
    <button class="action-btn" title="Show row colour legend" onclick="var p=this.parentNode.querySelector('.ab-popup'); p.style.display=p.style.display==='none'?'block':'none';">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"/>
      </svg>
      Legend
    </button>
    <div class="ab-popup" style="display:none;">
      <div class="ab-popup-header">Row Colour Legend <button class="ab-popup-close" onclick="this.closest('.ab-popup').style.display='none'">&times;</button></div>
      <div class="ab-legend-row"><span class="ab-legend-dot" style="background:#7F1D1D;"></span> Red — Banned customer</div>
      <div class="ab-legend-row"><span class="ab-legend-dot" style="background:#FEF9C3;border:1px solid #D97706;"></span> Yellow — Returning, no Cash Paid</div>
      <div class="ab-legend-row"><span class="ab-legend-dot" style="background:#14532D;"></span> Green — VIP (has Cash Paid)</div>
      <div class="ab-legend-row"><span class="ab-legend-dot" style="background:#fff;border:1px solid #D1D5DB;"></span> White — New customer</div>
    </div>
  </div>

  <!-- Only Me -->
  <button id="only-me-btn" class="action-btn" title="Show only my orders" onclick="
    var btn=this; var active=btn.classList.toggle('ab-only-me-active');
    var x=btn.querySelector('.ab-only-me-x'); x.style.display=active?'inline':'none';
    if(active) htmx.ajax('GET','/api/csr/orders?page=1&only_me=1&hygiene=all',{target:'#order-table-container',swap:'innerHTML'});
    else htmx.ajax('GET','/api/csr/orders?page=1&hygiene=all',{target:'#order-table-container',swap:'innerHTML'});
  ">
    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
      <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
    </svg>
    Only Me
    <span class="ab-only-me-x" style="display:none;" onclick="event.stopPropagation(); var btn=document.getElementById('only-me-btn'); btn.classList.remove('ab-only-me-active'); this.style.display='none'; htmx.ajax('GET','/api/csr/orders?page=1&hygiene=all',{target:'#order-table-container',swap:'innerHTML'});">&times;</span>
  </button>

  <!-- Filter -->
  <button class="action-btn" title="Filter orders">
    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z"/>
    </svg>
    Filter
  </button>

  <!-- Sort -->
  <button class="action-btn" title="Sort orders">
    <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3 4h13M3 8h9m-9 4h6m4 0l4-4m0 0l4 4m-4-4v12"/>
    </svg>
    Sort
  </button>

  <!-- Color filter -->
  <div style="position:relative;">
    <button class="action-btn active-color" title="Colour filter" onclick="var p=this.parentNode.querySelector('.ab-popup'); p.style.display=p.style.display==='none'?'block':'none';">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
      </svg>
      Color
    </button>
    <div class="ab-popup ab-color-popup" style="display:none;">
      <button class="ab-color-opt" onclick="document.querySelectorAll('#order-table tbody tr').forEach(r=>{r.style.display=r.classList.contains('row-green')?'':'none'}); this.closest('.ab-popup').style.display='none'">
        <span class="ab-legend-dot" style="background:#14532D;"></span> Green (VIP)
      </button>
      <button class="ab-color-opt" onclick="document.querySelectorAll('#order-table tbody tr').forEach(r=>{r.style.display=r.classList.contains('row-yellow')?'':'none'}); this.closest('.ab-popup').style.display='none'">
        <span class="ab-legend-dot" style="background:#FEF9C3;border:1px solid #D97706;"></span> Yellow (Returning)
      </button>
      <button class="ab-color-opt" onclick="document.querySelectorAll('#order-table tbody tr').forEach(r=>{r.style.display=r.classList.contains('row-red')?'':'none'}); this.closest('.ab-popup').style.display='none'">
        <span class="ab-legend-dot" style="background:#7F1D1D;"></span> Red (Banned)
      </button>
      <button class="ab-color-opt" style="border-top:1px solid #E5E7EB;margin-top:4px;padding-top:8px;" onclick="document.querySelectorAll('#order-table tbody tr').forEach(r=>{r.style.display=''}); this.closest('.ab-popup').style.display='none'">
        Show All
      </button>
    </div>
  </div>

  <!-- Search -->
  <div style="display:flex;align-items:center;gap:4px;">
    <button class="action-btn" title="Search by phone or order ID" onclick="var inp=this.parentNode.querySelector('.ab-search-input'); if(inp.style.display==='none'){inp.style.display='block';inp.focus();}else{inp.style.display='none';inp.value='';}">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
      </svg>
    </button>
    <input class="ab-search-input" type="text" placeholder="Phone or Order ID..." style="display:none;"
           onkeydown="if(event.key==='Escape'){this.style.display='none';this.value='';} if(event.key==='Enter'&&this.value.trim()){htmx.ajax('GET','/api/csr/orders?page=1&search='+encodeURIComponent(this.value.trim())+'&hygiene=all',{target:'#order-table-container',swap:'innerHTML'});}">
  </div>

  <!-- New Order button (right-aligned) — opens panel in Workflow B mode -->
  <button class="action-btn-new"
          onclick="Alpine.store('ui').panelOpen = true; Alpine.store('ui').currentOrderId = null; htmx.ajax('GET', '/api/csr/orders/new', {target:'#slide-out-body', swap:'innerHTML'});">
    New
  </button>
</div>

<div id="grid-wrapper">
  <div id="grid-spinner">Loading&hellip;</div>
  <div id="order-table-container">
    <%- include('./order-grid', { rows, total, page, limit, hygiene, queryString: '' }) %>
  </div>
</div>
