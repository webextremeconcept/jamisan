<%
/*
 * slide-out-panel.ejs — Order detail popup panel.
 * Receives: order (full object from getOrderById with all JOINs)
 * Injected into #slide-out-body via HTMX.
 *
 * Layout matches mockup: icon | label | input in 3-column rows
 * Right panel: Snapshot + Behavorial Tags + Feed
 */
function fmtDate(d) {
  if (!d) return '';
  return new Date(d).toISOString().split('T')[0];
}
function fmtDateDisplay(d) {
  if (!d) return '';
  return new Date(d).toLocaleDateString('en-NG', { hour:'numeric', minute:'2-digit', hour12:true, day:'2-digit', month:'short', year:'numeric' }).toUpperCase();
}
function fmtMoney(n) {
  if (n == null || n === '') return '';
  return 'N' + Number(n).toLocaleString();
}

const o = order;
const dfo = o.ordered_at ? Math.floor((Date.now() - new Date(o.ordered_at).getTime()) / 86400000) : 0;
const successRate = o.customer_total_orders > 0
  ? Math.round((o.total_purchases || 0) / o.customer_total_orders * 100)
  : 0;

const statusGroups = [
  { label: 'Active/Positive', statuses: ['Interested','Pending','Scheduled','Committed Immediate','Committed Scheduled','Cash Paid'] },
  { label: 'Unreachable', statuses: ['Not Picking Calls','Switched Off','Will Call Me Back','To Call Back','Direct WhatsApp','Not Reachable','Invalid Number','No Phone Number','Ignored Agents Call'] },
  { label: 'Failed/Negative', statuses: ['Failed','Cancelled','Returned','Banned',"Didn't Order",'Got It Elsewhere','Not Ready to Pay'] },
  { label: 'Conditional', statuses: ['Haggling','Changed Location','Location Requires Waybill','Out of the Way','Out of Stock','From Social Media'] },
  { label: 'System/Admin', statuses: ['Test','Abandoned','CSR Skipped','Duplicate Order'] },
];
%>

<!-- ═══ TOP ACTION BAR ═══ -->
<div class="pp-topbar" x-data="{ confirmLeave: false }">
  <div class="pp-topbar-left">
    <!-- Up/Down order navigation -->
    <button class="pp-circle-orange" title="Previous order"
            onclick="Alpine.store('ui').navigateOrder('prev')">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
    </button>
    <button class="pp-circle-orange" title="Next order"
            onclick="Alpine.store('ui').navigateOrder('next')">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
    </button>
    <button class="pp-circle-orange" title="Save" type="submit" form="pp-form-<%= o.id %>">
      <svg width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 21H7a2 2 0 01-2-2V5a2 2 0 012-2h7l5 5v11a2 2 0 01-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
    </button>
    <button class="pp-copy-btn" onclick="copyOrderText(<%= o.id %>)" title="Copy order to clipboard">
      <svg width="14" height="14" fill="none" stroke="#F59E0B" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 5H6a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2v-1M8 5a2 2 0 002 2h2a2 2 0 002-2M8 5a2 2 0 012-2h2a2 2 0 012 2m0 0h2a2 2 0 012 2v3m2 4H10m0 0l3-3m-3 3l3 3"/></svg>
      Copy Order
    </button>
  </div>
  <div class="pp-topbar-right">
    <span class="pp-editing-badge">Editing Mode</span>
    <!-- Collapse chevron — dark circle, rotates based on state -->
    <button class="pp-circle-dark"
            @click="$store.ui.panelRightCollapsed = !$store.ui.panelRightCollapsed"
            title="Toggle intel panel">
      <svg class="pp-chevron-svg" width="14" height="14" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/></svg>
    </button>
    <!-- X close — guarded by unsaved changes check -->
    <button class="pp-x-close"
            @click="$store.ui.hasUnsavedChanges ? (confirmLeave = true) : $store.ui.closePanel()"
            title="Close">&times;</button>
  </div>

  <!-- Unsaved changes confirmation modal -->
  <div class="pp-confirm-overlay" x-show="confirmLeave" x-cloak>
    <div class="pp-confirm-card" @click.stop>
      <div class="pp-confirm-title">Unsaved Changes</div>
      <div class="pp-confirm-body">You have unsaved changes that will be lost. Are you sure you want to leave?</div>
      <div class="pp-confirm-actions">
        <button class="btn btn-ghost" @click="confirmLeave = false">Cancel</button>
        <button class="btn btn-danger" @click="$store.ui.hasUnsavedChanges = false; $store.ui.closePanel(); confirmLeave = false">Leave Without Saving</button>
      </div>
    </div>
  </div>
</div>

<!-- ═══ ORDER SUMMARY HEADER ═══ -->
<div class="pp-summary">
  <div class="pp-summary-line1">
    Order #<span class="pp-orange"><%= o.row_num || '' %></span> for <span class="pp-orange"><%= o.csr_name || '' %></span>
    (<span class="pp-orange"><%= o.order_id %></span>) - DFO (<%= dfo %> Days)
  </div>
  <div class="pp-summary-line2">
    <span class="pp-orange"><%= o.order_id %></span> - <%= o.customer_name ? o.customer_name.toUpperCase() : '' %>
    (<%= fmtDateDisplay(o.ordered_at) %>)
  </div>
  <div class="pp-divider"></div>
</div>

<!-- ═══ BODY: LEFT FORM + RIGHT INTEL ═══ -->
<div class="pp-body">

  <!-- ──── LEFT: Form ──── -->
  <div class="pp-form-col">
    <form id="pp-form-<%= o.id %>"
          hx-patch="/api/csr/orders/<%= o.id %>"
          hx-target="#order-row-<%= o.id %>"
          hx-swap="outerHTML"
          hx-ext="json-enc"
          x-on:change="$store.ui.hasUnsavedChanges = true"
          @order-saved-success.window="$store.ui.hasUnsavedChanges = false;">

      <!-- Phone Number -->
      <div class="pp-row">
        <div class="pp-icon"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3"/></svg></div>
        <label class="pp-label">Phone Number</label>
        <input type="text" class="pp-input" value="<%= o.phone_number || '' %>" readonly>
      </div>

      <!-- Other Number -->
      <div class="pp-row">
        <div class="pp-icon"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/></svg></div>
        <label class="pp-label">Other Number</label>
        <input type="text" class="pp-input" name="other_phone" value="<%= o.other_phone || '' %>">
      </div>

      <!-- Status -->
      <div class="pp-row">
        <div class="pp-icon"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15a2.25 2.25 0 012.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"/></svg></div>
        <label class="pp-label">Status</label>
        <select class="pp-input" name="status">
          <% statusGroups.forEach(function(grp) { %>
            <optgroup label="<%= grp.label %>">
              <% grp.statuses.forEach(function(s) { %>
                <option value="<%= s %>"<%= o.status === s ? ' selected' : '' %>><%= s %></option>
              <% }); %>
            </optgroup>
          <% }); %>
        </select>
      </div>

      <!-- Comments -->
      <div class="pp-row pp-row-tall">
        <div class="pp-icon"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.087.16 2.185.283 3.293.369V21l4.076-4.076a1.526 1.526 0 011.037-.443 48.282 48.282 0 005.68-.494c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/></svg></div>
        <label class="pp-label">Comments</label>
        <textarea class="pp-input" name="comments" rows="3"><%= o.comments || '' %></textarea>
      </div>

      <!-- Agent -->
      <div class="pp-row pp-row-agent">
        <div class="pp-icon"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.25 18.75a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0h6m-9 0H3.375a1.125 1.125 0 01-1.125-1.125V14.25m17.25 4.5a1.5 1.5 0 01-3 0m3 0a1.5 1.5 0 00-3 0m3 0H6.375m11.25 0h3.375c.621 0 1.125-.504 1.125-1.125v-3.656a2.25 2.25 0 00-.659-1.591l-2.4-2.399a2.25 2.25 0 00-1.591-.659H18M6.375 18.75h-.375a3 3 0 01-3-3V8.25m0 0h4.5m-4.5 0v-.375c0-.621.504-1.125 1.125-1.125H6m12 0V5.625m0 0h-2.25A1.125 1.125 0 0014.625 4.5V3"/></svg></div>
        <label class="pp-label">Agent</label>
        <select class="pp-input" name="agent_id" id="panel-agent-<%= o.id %>">
          <option value="">— Select Agent —</option>
          <% if (o.agent_id) { %><option value="<%= o.agent_id %>" selected><%= o.agent_name %></option><% } %>
        </select>
        <a href="<%= o.agent_wa_link || '#' %>"
           target="_blank"
           title="Open agent strategy link"
           class="pp-agent-link"
           style="<%= !o.agent_wa_link ? 'opacity:0.3;pointer-events:none;' : '' %>">
          <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.818-1.757l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>
        </a>
      </div>

      <!-- Date Paid -->
      <div class="pp-row">
        <div class="pp-icon"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg></div>
        <label class="pp-label">Date Paid</label>
        <input type="date" class="pp-input" name="date_paid" value="<%= fmtDate(o.date_paid) %>">
      </div>

      <!-- Product Price -->
      <div class="pp-row">
        <div class="pp-icon"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z"/></svg></div>
        <label class="pp-label">Product Price</label>
        <input type="number" class="pp-input" name="price" value="<%= o.price || '' %>" min="0" step="100">
      </div>

      <!-- State -->
      <div class="pp-row">
        <div class="pp-icon"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg></div>
        <label class="pp-label">State</label>
        <select class="pp-input" name="admin_level_1_id" id="panel-state-<%= o.id %>"
                hx-get="/api/csr/lookups/states-options"
                hx-trigger="load"
                hx-target="this"
                hx-swap="beforeend"
                onchange="
                  htmx.ajax('GET', '/api/csr/lookups/lgas?admin_level_1_id=' + this.value, {target: '#panel-lga-<%= o.id %>', swap: 'innerHTML'});
                  htmx.ajax('GET', '/api/csr/lookups/agents-by-state?admin_level_1_id=' + this.value, {target: '#panel-agent-<%= o.id %>', swap: 'innerHTML'});
                ">
          <option value="">— Select State —</option>
          <% if (o.admin_level_1_id) { %><option value="<%= o.admin_level_1_id %>" selected><%= o.state_name %></option><% } %>
        </select>
      </div>

      <!-- LGA -->
      <div class="pp-row">
        <div class="pp-icon"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg></div>
        <label class="pp-label">LGA</label>
        <select class="pp-input" name="admin_level_2_id" id="panel-lga-<%= o.id %>">
          <option value="">— Select LGA —</option>
          <% if (o.admin_level_2_id) { %><option value="<%= o.admin_level_2_id %>" selected><%= o.lga_name %></option><% } %>
        </select>
      </div>

      <!-- Sex -->
      <div class="pp-row">
        <div class="pp-icon"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/></svg></div>
        <label class="pp-label">Sex</label>
        <select class="pp-input" name="sex">
          <option value="">--Select Sex--</option>
          <option value="Male"<%= o.sex === 'Male' ? ' selected' : '' %>>Male</option>
          <option value="Female"<%= o.sex === 'Female' ? ' selected' : '' %>>Female</option>
        </select>
      </div>

      <!-- Logistics Fee -->
      <div class="pp-row">
        <div class="pp-icon"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75"/></svg></div>
        <label class="pp-label">Logistics Fee</label>
        <input type="number" class="pp-input" name="logistics_fee" value="<%= o.logistics_fee || '' %>" min="0" step="100">
      </div>

      <!-- Main Product -->
      <div class="pp-row">
        <div class="pp-icon"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25"/></svg></div>
        <label class="pp-label">Main Product</label>
        <select class="pp-input" name="product_id"
                hx-get="/api/csr/lookups/products-options"
                hx-trigger="load"
                hx-target="this"
                hx-swap="beforeend">
          <option value="">— Select Product —</option>
          <% if (o.product_id) { %><option value="<%= o.product_id %>" selected><%= o.product_name %></option><% } %>
        </select>
      </div>

      <!-- Quantity (Main) -->
      <div class="pp-row">
        <div class="pp-icon"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L12 12.75 6.429 9.75M17.571 12l4.179 2.25L12 19.5l-9.75-5.25L6.429 12"/></svg></div>
        <label class="pp-label">Quantity(Main)</label>
        <input type="number" class="pp-input" name="quantity" value="<%= o.quantity || 1 %>" min="1">
      </div>

      <!-- Order Bump -->
      <div class="pp-row">
        <div class="pp-icon"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M21 7.5l-9-5.25L3 7.5m18 0l-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25"/></svg></div>
        <label class="pp-label">Order Bump</label>
        <select class="pp-input">
          <option value="no"<%= !o.has_order_bump ? ' selected' : '' %>>No</option>
          <option value="yes"<%= o.has_order_bump ? ' selected' : '' %>>Yes</option>
        </select>
      </div>

      <!-- Quantity (Bump) -->
      <div class="pp-row">
        <div class="pp-icon"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.429 9.75L2.25 12l4.179 2.25m0-4.5l5.571 3 5.571-3m-11.142 0L2.25 7.5 12 2.25l9.75 5.25-4.179 2.25m0 0L12 12.75 6.429 9.75M17.571 12l4.179 2.25L12 19.5l-9.75-5.25L6.429 12"/></svg></div>
        <label class="pp-label">Quantity(Bump)</label>
        <input type="number" class="pp-input" name="order_bump_quantity" value="<%= o.order_bump_quantity || 0 %>" min="0">
      </div>

      <!-- City -->
      <div class="pp-row">
        <div class="pp-icon"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/></svg></div>
        <label class="pp-label">City</label>
        <input type="text" class="pp-input" name="city" value="<%= o.city || '' %>">
      </div>

      <!-- Address -->
      <div class="pp-row">
        <div class="pp-icon"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg></div>
        <label class="pp-label">Address</label>
        <input type="text" class="pp-input" name="full_address" value="<%= o.full_address || '' %>">
      </div>

      <!-- Email -->
      <div class="pp-row">
        <div class="pp-icon"><svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zm0 0c0 1.657 1.007 3 2.25 3S21 13.657 21 12a9 9 0 10-2.636 6.364M16.5 12V8.25"/></svg></div>
        <label class="pp-label">Email</label>
        <input type="email" class="pp-input" name="email" value="<%= o.email || '' %>">
      </div>

      <!-- Name -->
      <div class="pp-row">
        <label class="pp-label" style="grid-column:1/3;">Name</label>
        <input type="text" class="pp-input pp-readonly" value="<%= o.customer_name || '' %>" readonly>
      </div>

    </form>
  </div>

  <!-- ──── RIGHT: Intel Panel ──── -->
  <div class="pp-intel">

    <!-- View switcher dropdown -->
    <div class="pp-intel-header">
      <select class="pp-view-select" onchange="
        var h = this.closest('.pp-intel').querySelector('.pp-view-history');
        var c = this.closest('.pp-intel').querySelector('.pp-view-calc');
        if (this.value === 'history') { h.style.display = 'block'; c.style.display = 'none'; }
        else { h.style.display = 'none'; c.style.display = 'block'; }
      ">
        <option value="history">History</option>
        <option value="calc">Calculated Fields</option>
      </select>
    </div>

    <!-- ── History view (default visible) ── -->
    <div class="pp-view-history">
      <div class="pp-intel-section">
        <div class="pp-intel-title">SNAPSHOT</div>
        <div class="pp-snapshot-grid">
          <div>Total Orders: <strong><%= o.customer_total_orders || 0 %></strong></div>
          <div>Cash Paid Orders: <strong><%= o.total_purchases || 0 %></strong></div>
          <div>Delivery Success Rate: <strong><%= successRate %>%</strong></div>
          <div>Total Lifetime Value: <strong><%= fmtMoney(o.lifetime_value || 0) %></strong></div>
        </div>
      </div>

      <div class="pp-intel-section">
        <div class="pp-intel-title">BEHAVORIAL TAGS</div>
        <div class="pp-tags">
          <% if (o.total_purchases > 0) { %>
            <span class="pp-tag pp-tag-green">Verified Buyer</span>
          <% } %>
          <% if (o.customer_tag) { %>
            <span class="pp-tag pp-tag-blue"><%= o.customer_tag %></span>
          <% } %>
          <% if (o.is_banned) { %>
            <span class="pp-tag pp-tag-red">BANNED</span>
          <% } %>
          <% if ((o.customer_total_orders || 0) > 1) { %>
            <span class="pp-tag pp-tag-orange">Returning Customer</span>
          <% } %>
        </div>
      </div>

      <div class="pp-intel-section">
        <div class="pp-intel-title">FEED</div>
        <div id="panel-order-feed"
             hx-get="/api/csr/orders/<%= o.id %>/customer"
             hx-trigger="load"
             hx-swap="innerHTML">
          <div style="padding:8px;color:#9CA3AF;font-size:0.8rem;">Loading...</div>
        </div>
      </div>
    </div>

    <!-- ── Calculated Fields view (toggled by switcher) ── -->
    <div class="pp-view-calc pp-calc-fields" style="display:none;">
      <div class="pp-calc-row">
        <span class="pp-calc-label">Assigned Weekday</span>
        <span class="pp-calc-value"><%= o.assigned_weekday || '—' %></span>
      </div>
      <div class="pp-calc-row">
        <span class="pp-calc-label">System Log Time</span>
        <span class="pp-calc-value"><%= fmtDateDisplay(o.ordered_at) || '—' %></span>
      </div>
      <div class="pp-calc-row">
        <span class="pp-calc-label">Last Modified</span>
        <span class="pp-calc-value"><%= fmtDateDisplay(o.updated_at) || '—' %></span>
      </div>
      <div class="pp-calc-row">
        <span class="pp-calc-label">API Batch ID</span>
        <span class="pp-calc-value" style="font-family:monospace;font-size:0.7rem;"><%= o.api_batch_id || '—' %></span>
      </div>
    </div>

    <!-- ── Calculated Fields (always visible below feed) ── -->
    <div class="pp-intel-section pp-calc-fields" style="margin-top:8px;">
      <div class="pp-intel-title">CALCULATED FIELDS</div>
      <div class="pp-calc-row">
        <span class="pp-calc-label">Assigned Weekday</span>
        <span class="pp-calc-value"><%= o.assigned_weekday || '—' %></span>
      </div>
      <div class="pp-calc-row">
        <span class="pp-calc-label">System Log Time</span>
        <span class="pp-calc-value"><%= fmtDateDisplay(o.ordered_at) || '—' %></span>
      </div>
      <div class="pp-calc-row">
        <span class="pp-calc-label">Last Modified</span>
        <span class="pp-calc-value"><%= fmtDateDisplay(o.updated_at) || '—' %></span>
      </div>
      <div class="pp-calc-row">
        <span class="pp-calc-label">API Batch ID</span>
        <span class="pp-calc-value" style="font-family:monospace;font-size:0.7rem;"><%= o.api_batch_id || '—' %></span>
      </div>
    </div>

  </div>

</div>
