<%
/* sidebar.ejs — expects: user { display_name, role_name, is_on_break }
   Nav items: Workspace, Reports, Inventory, Complaints, Settings (bottom) */
const initials = (user.display_name || 'U').charAt(0).toUpperCase();
const firstName = (user.display_name || '').split(' ')[0] || 'User';
%>

<div id="sidebar"
     x-data>

  <!-- Sidebar toggle button (red circle, chevron, right edge) -->
  <button id="sidebar-toggle"
          @click="$store.ui.toggleSidebar()"
          title="Toggle sidebar">
    <svg class="sidebar-toggle-chevron" width="10" height="10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="3">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"/>
    </svg>
  </button>

  <!-- Logo — visibility driven by CSS via .collapsed class on #sidebar -->
  <div class="sidebar-logo">
    <img src="/img/jamisan-logo.png" alt="Jamisan ERP" class="logo-full">
    <img src="/img/jamisan-logo-collapsed.png" alt="J" class="logo-collapsed">
  </div>

  <!-- Navigation items -->
  <nav style="flex:1;padding:4px 0;overflow-y:auto;overflow-x:hidden;">

    <a href="/dashboard"
       class="nav-item <%= locals.activePage === 'workspace' ? 'active' : '' %>"
       hx-get="/api/csr/dashboard"
       hx-target="#page-content"
       hx-swap="innerHTML"
       hx-push-url="/dashboard">
      <!-- Monitor icon -->
      <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
      </svg>
      <span class="nav-label">Workspace</span>
    </a>

    <a href="#" class="nav-item">
      <!-- Bar chart icon -->
      <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
      </svg>
      <span class="nav-label">Reports</span>
    </a>

    <a href="#" class="nav-item">
      <!-- Box / cube icon -->
      <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
      </svg>
      <span class="nav-label">Inventory</span>
    </a>

    <a href="#" class="nav-item">
      <!-- Chat / complaints icon -->
      <svg class="nav-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
      </svg>
      <span class="nav-label">Complaints</span>
    </a>

  </nav>

  <!-- Bottom bar — vertical stack: On Break / Settings / User -->
  <div id="sidebar-bottom" class="sidebar-bottom-stack">

    <!-- Row 1: On Break -->
    <button hx-patch="/api/csr/break" hx-swap="none"
            x-on:htmx:after-request="$store.ui.onBreak = !$store.ui.onBreak; showToast($store.ui.onBreak ? 'You are now on break ☕' : 'Welcome back! 👋', 'info')"
            class="sidebar-bottom-item"
            :class="$store.ui.onBreak ? 'sb-on-break-active' : ''">
      <span class="sb-icon-slot">☕</span>
      <span class="sb-label nav-label">On Break</span>
    </button>

    <!-- Row 2: Settings -->
    <a href="#" class="sidebar-bottom-item">
      <svg class="sb-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
        <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
      </svg>
      <span class="sb-label nav-label">Settings</span>
    </a>

    <!-- Row 3: User profile (expanded) / Logout icon (collapsed) -->
    <div class="sidebar-bottom-user nav-label">
      <div class="sb-user-inner">
        <div class="sb-avatar"><%= initials %></div>
        <div class="sb-username"><%= firstName %></div>
      </div>
      <button onclick="logout()" class="sb-logout" title="Logout">
        <svg width="16" height="16" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round"
                d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
        </svg>
      </button>
    </div>

    <!-- Collapsed-only: standalone logout icon -->
    <button onclick="logout()" class="sidebar-bottom-item sb-collapsed-logout" title="Logout">
      <svg class="sb-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round"
              d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
      </svg>
    </button>

  </div><!-- /#sidebar-bottom -->

</div><!-- /#sidebar -->
