<%
/*
 * order-grid.ejs — full 17-column order table + pagination.
 * Receives: rows, total, page, limit, hygiene, queryString (all active filters encoded)
 * Rendered by: getOrders (HTMX partial swap into #order-table-container)
 *              getDashboard (initial render inside dashboard.ejs)
 *
 * queryString: pre-built string of all active params except 'page', e.g. "&hygiene=skipped&search=0801"
 * HTMX pagination always appends full queryString so filters are never lost.
 * hx-push-url="true" on all pagination buttons so refresh preserves position.
 */
const totalPages = Math.ceil(total / limit) || 1;
const qs = typeof queryString !== 'undefined' ? queryString : ('&hygiene=' + (hygiene || 'all'));
%>

<table id="order-table">
  <thead>
    <tr>
      <th style="width:44px;text-align:right;">#</th>
      <th style="width:110px;" class="sortable-th" onclick="sortGrid(this, 1)">Order ID</th>
      <th style="width:100px;" class="sortable-th" onclick="sortGrid(this, 2)">CSR</th>
      <th style="width:90px;" class="sortable-th" onclick="sortGrid(this, 3)">Date</th>
      <th style="width:46px;text-align:center;" class="sortable-th" onclick="sortGrid(this, 4)">DFO</th>
      <th style="width:150px;" class="sortable-th" onclick="sortGrid(this, 5)">Customer</th>
      <th style="width:130px;">Phone</th>
      <th style="width:160px;" class="sortable-th" onclick="sortGrid(this, 7)">Product</th>
      <th style="width:80px;" class="sortable-th" onclick="sortGrid(this, 8)">Colour</th>
      <th style="width:90px;text-align:right;" class="sortable-th" onclick="sortGrid(this, 9)">Price</th>
      <th style="width:100px;" class="sortable-th" onclick="sortGrid(this, 10)">State</th>
      <th style="width:100px;" class="sortable-th" onclick="sortGrid(this, 11)">LGA</th>
      <th style="width:150px;" class="sortable-th" onclick="sortGrid(this, 12)">Agent</th>
      <th style="width:175px;" class="sortable-th" onclick="sortGrid(this, 13)">Status</th>
      <th style="min-width:180px;">Comments</th>
      <th style="width:90px;" class="sortable-th" onclick="sortGrid(this, 15)">Date Paid</th>
      <th style="width:60px;" class="sortable-th" onclick="sortGrid(this, 16)">Sex</th>
    </tr>
  </thead>
  <tbody>
    <% if (!rows || rows.length === 0) { %>
      <!-- Preview rows (no DB) -->
      <tr class="order-row row-green"><td style="text-align:right;color:#9CA3AF;font-size:0.75rem;padding:0 8px;">10000</td><td style="padding:0 8px;"><span class="order-id-link">FJAMG1271</span></td><td style="padding:0 8px;">Ohambele</td><td style="padding:0 8px;">25/03/26</td><td style="padding:0 8px;text-align:center;">2</td><td style="padding:0 8px;">FAITH AJOGBOR</td><td style="padding:0 8px;">2349010641483</td><td style="padding:0 8px;">Temique Stretchmarks</td><td style="padding:0 8px;">Red</td><td style="padding:0 8px;text-align:right;">&#8358;19,500</td><td style="padding:0 8px;">Imo</td><td style="padding:0 8px;">Oru East</td><td style="padding:0 8px;">—</td><td style="padding:0 4px;"><select class="inline-edit" style="width:100%;font-size:0.78rem;"><option selected>Cash Paid</option></select></td><td style="padding:0 4px;">delivered</td><td style="padding:0 8px;">25/03/26</td><td style="padding:0 8px;">Female</td></tr>
      <tr class="order-row"><td style="text-align:right;color:#9CA3AF;font-size:0.75rem;padding:0 8px;">9999</td><td style="padding:0 8px;"><span class="order-id-link">FJAME1778</span></td><td style="padding:0 8px;">Ayomide</td><td style="padding:0 8px;">25/03/26</td><td style="padding:0 8px;text-align:center;">3</td><td style="padding:0 8px;">Isah Musa</td><td style="padding:0 8px;">2349049954610</td><td style="padding:0 8px;">Temique Stretchmarks</td><td style="padding:0 8px;">Blue</td><td style="padding:0 8px;text-align:right;">&#8358;19,500</td><td style="padding:0 8px;">Anambra</td><td style="padding:0 8px;">Awka South</td><td style="padding:0 8px;">—</td><td style="padding:0 4px;"><select class="inline-edit" style="width:100%;font-size:0.78rem;"><option selected>Interested</option></select></td><td style="padding:0 4px;">—</td><td style="padding:0 8px;">—</td><td style="padding:0 8px;">—</td></tr>
      <tr class="order-row"><td style="text-align:right;color:#9CA3AF;font-size:0.75rem;padding:0 8px;">9998</td><td style="padding:0 8px;"><span class="order-id-link">FJAME1777</span></td><td style="padding:0 8px;">Doyin</td><td style="padding:0 8px;">25/03/26</td><td style="padding:0 8px;text-align:center;">1</td><td style="padding:0 8px;">Awo Stella Ezinne</td><td style="padding:0 8px;">2347048451908</td><td style="padding:0 8px;">Temique DarkSpot Serum</td><td style="padding:0 8px;">Green</td><td style="padding:0 8px;text-align:right;">&#8358;19,500</td><td style="padding:0 8px;">Abuja</td><td style="padding:0 8px;">Abuja Municipal</td><td style="padding:0 8px;">—</td><td style="padding:0 4px;"><select class="inline-edit" style="width:100%;font-size:0.78rem;"><option selected>Not Picking Calls</option></select></td><td style="padding:0 4px;">Customer not picking calls</td><td style="padding:0 8px;">—</td><td style="padding:0 8px;">Female</td></tr>
      <tr class="order-row row-red"><td style="text-align:right;color:#9CA3AF;font-size:0.75rem;padding:0 8px;">9994</td><td style="padding:0 8px;"><span class="order-id-link">FJAME1773</span></td><td style="padding:0 8px;">Ayomide</td><td style="padding:0 8px;">25/03/26</td><td style="padding:0 8px;text-align:center;">1</td><td style="padding:0 8px;">Kezzy</td><td style="padding:0 8px;">2348130757890</td><td style="padding:0 8px;">Temique Stretchmarks</td><td style="padding:0 8px;">Red</td><td style="padding:0 8px;text-align:right;">&#8358;19,500</td><td style="padding:0 8px;">Abuja</td><td style="padding:0 8px;">Gwagwalada</td><td style="padding:0 8px;">—</td><td style="padding:0 4px;"><select class="inline-edit" style="width:100%;font-size:0.78rem;"><option selected>Banned</option></select></td><td style="padding:0 4px;">—</td><td style="padding:0 8px;">—</td><td style="padding:0 8px;">—</td></tr>
      <tr class="order-row row-yellow"><td style="text-align:right;color:#9CA3AF;font-size:0.75rem;padding:0 8px;">9990</td><td style="padding:0 8px;"><span class="order-id-link">FJAME1769</span></td><td style="padding:0 8px;">Doyin</td><td style="padding:0 8px;">25/03/26</td><td style="padding:0 8px;text-align:center;">1</td><td style="padding:0 8px;">Tomike</td><td style="padding:0 8px;">2349130567955</td><td style="padding:0 8px;">Temique Stretchmarks</td><td style="padding:0 8px;">Blue</td><td style="padding:0 8px;text-align:right;">&#8358;19,500</td><td style="padding:0 8px;">Akwa Ibom</td><td style="padding:0 8px;">Ibesikpo Asutan</td><td style="padding:0 8px;">—</td><td style="padding:0 4px;"><select class="inline-edit" style="width:100%;font-size:0.78rem;"><option selected>Interested</option></select></td><td style="padding:0 4px;">—</td><td style="padding:0 8px;">—</td><td style="padding:0 8px;">—</td></tr>
      <tr class="order-row row-green"><td style="text-align:right;color:#9CA3AF;font-size:0.75rem;padding:0 8px;">9989</td><td style="padding:0 8px;"><span class="order-id-link">FJAME1768</span></td><td style="padding:0 8px;">Doyin</td><td style="padding:0 8px;">25/03/26</td><td style="padding:0 8px;text-align:center;">1</td><td style="padding:0 8px;">Joel Fredrick</td><td style="padding:0 8px;">2347063560691</td><td style="padding:0 8px;">Temique Acne Gel</td><td style="padding:0 8px;">Green</td><td style="padding:0 8px;text-align:right;">&#8358;19,500</td><td style="padding:0 8px;">Lagos</td><td style="padding:0 8px;">Lagos Mainland</td><td style="padding:0 8px;">—</td><td style="padding:0 4px;"><select class="inline-edit" style="width:100%;font-size:0.78rem;"><option selected>To Call Back</option></select></td><td style="padding:0 4px;">Line is busy</td><td style="padding:0 8px;">—</td><td style="padding:0 8px;">Female</td></tr>
    <% } else { %>
      <% rows.forEach(function(row) { %>
        <%- include('./order-row', { o: row }) %>
      <% }); %>
    <% } %>
  </tbody>
</table>

<%
const startPage = Math.max(1, page - 2);
const endPage   = Math.min(totalPages, page + 2);
%>
<div id="pagination">
  <!-- Rows per page -->
  <span class="rows-per-page-label">Rows per page:</span>
  <select class="rows-per-page-select"
          onchange="htmx.ajax('GET', '/api/csr/orders?page=1&limit=' + this.value + '<%= qs %>', { target: '#order-table-container', swap: 'innerHTML' })">
    <option value="50"  <%= limit === 50  ? 'selected' : '' %>>50</option>
    <option value="100" <%= limit === 100 ? 'selected' : '' %>>100</option>
    <option value="150" <%= limit === 150 ? 'selected' : '' %>>150</option>
    <option value="300" <%= limit === 300 ? 'selected' : '' %>>300</option>
  </select>

  <!-- First page ⟨⟨ -->
  <% if (page > 1) { %>
    <button class="page-btn"
            hx-get="/api/csr/orders?page=1&limit=<%= limit %><%= qs %>"
            hx-target="#order-table-container"
            hx-swap="innerHTML"
            hx-push-url="true"
            hx-indicator="#grid-spinner"
            title="First page">⟨⟨</button>
    <!-- Previous ⟨ -->
    <button class="page-btn"
            hx-get="/api/csr/orders?page=<%= page - 1 %>&limit=<%= limit %><%= qs %>"
            hx-target="#order-table-container"
            hx-swap="innerHTML"
            hx-push-url="true"
            hx-indicator="#grid-spinner"
            title="Previous page">⟨</button>
  <% } else { %>
    <button class="page-btn" disabled>⟨⟨</button>
    <button class="page-btn" disabled>⟨</button>
  <% } %>

  <!-- Page number buttons -->
  <% for (let p = startPage; p <= endPage; p++) { %>
    <button class="page-btn <%= p === page ? 'active' : '' %>"
            hx-get="/api/csr/orders?page=<%= p %>&limit=<%= limit %><%= qs %>"
            hx-target="#order-table-container"
            hx-swap="innerHTML"
            hx-push-url="true"
            hx-indicator="#grid-spinner"><%= p %></button>
  <% } %>

  <!-- Ellipsis + last page if gap exists -->
  <% if (endPage < totalPages - 1) { %>
    <span class="page-ellipsis">…</span>
  <% } %>
  <% if (endPage < totalPages) { %>
    <button class="page-btn"
            hx-get="/api/csr/orders?page=<%= totalPages %>&limit=<%= limit %><%= qs %>"
            hx-target="#order-table-container"
            hx-swap="innerHTML"
            hx-push-url="true"
            hx-indicator="#grid-spinner"><%= totalPages %></button>
  <% } %>

  <!-- Next ⟩ -->
  <% if (page < totalPages) { %>
    <button class="page-btn"
            hx-get="/api/csr/orders?page=<%= page + 1 %>&limit=<%= limit %><%= qs %>"
            hx-target="#order-table-container"
            hx-swap="innerHTML"
            hx-push-url="true"
            hx-indicator="#grid-spinner"
            title="Next page">⟩</button>
    <!-- Last ⟩⟩ -->
    <button class="page-btn"
            hx-get="/api/csr/orders?page=<%= totalPages %>&limit=<%= limit %><%= qs %>"
            hx-target="#order-table-container"
            hx-swap="innerHTML"
            hx-push-url="true"
            hx-indicator="#grid-spinner"
            title="Last page">⟩⟩</button>
  <% } else { %>
    <button class="page-btn" disabled>⟩</button>
    <button class="page-btn" disabled>⟩⟩</button>
  <% } %>
</div>
