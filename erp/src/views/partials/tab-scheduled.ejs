<%
/*
 * tab-scheduled.ejs — Scheduled orders tab.
 * Receives: rows (array from getScheduledOrders)
 * Statuses: Scheduled, Committed Immediate, Committed Scheduled
 * Overdue = scheduled_date < today → red highlight
 */
const today = new Date().toISOString().split('T')[0];
function fmtDate(d) {
  if (!d) return '—';
  return new Date(d).toLocaleDateString('en-NG', { day:'2-digit', month:'short', year:'2-digit' });
}
function fmtMoney(n) {
  if (n == null) return '—';
  return '\u20A6' + Number(n).toLocaleString();
}
%>

<%- include('./top-nav', { activeTab: 'scheduled' }) %>

<div style="padding:16px 20px;border-bottom:1px solid #E5E7EB;">
  <strong style="font-size:0.8rem;letter-spacing:0.05em;color:#F59E0B;">SCHEDULED</strong>
  <span style="font-size:0.8rem;color:#9CA3AF;margin-left:12px;"><%= rows.length %> orders</span>
</div>

<div style="flex:1;overflow:auto;">
<table id="order-table">
  <thead>
    <tr>
      <th style="width:110px;">Order ID</th>
      <th style="width:150px;">Customer</th>
      <th style="width:130px;">Phone</th>
      <th style="width:160px;">Product</th>
      <th style="width:90px;text-align:right;">Price</th>
      <th style="width:120px;">Status</th>
      <th style="width:100px;">Scheduled</th>
      <th style="width:100px;">CSR</th>
      <th style="width:120px;">Agent</th>
      <th style="min-width:180px;">Comments</th>
    </tr>
  </thead>
  <tbody>
    <% if (rows.length === 0) { %>
      <tr><td colspan="10" style="text-align:center;padding:48px;color:#9CA3AF;font-style:italic;">No scheduled orders.</td></tr>
    <% } %>
    <% rows.forEach(function(r) { %>
      <%
        const sched = r.scheduled_date ? new Date(r.scheduled_date).toISOString().split('T')[0] : null;
        const overdue = sched && sched < today;
      %>
      <tr style="<%= overdue ? 'background:#FEF2F2;' : '' %>">
        <td style="padding:0 8px;"><span class="order-id-link" hx-get="/api/csr/orders/<%= r.id %>" hx-target="#slide-out-body" hx-swap="innerHTML" @click="$store.ui.panelOpen = true"><%= r.order_id %></span></td>
        <td style="padding:0 8px;"><%= r.customer_name %></td>
        <td style="padding:0 8px;"><%= r.phone_number %></td>
        <td style="padding:0 8px;"><%= r.product_name || '—' %></td>
        <td style="padding:0 8px;text-align:right;"><%= fmtMoney(r.price) %></td>
        <td style="padding:0 8px;"><%= r.status %></td>
        <td style="padding:0 8px;white-space:nowrap;<%= overdue ? 'color:#DC2626;font-weight:600;' : '' %>"><%= fmtDate(r.scheduled_date) %></td>
        <td style="padding:0 8px;"><%= r.csr_name || '—' %></td>
        <td style="padding:0 8px;"><%= r.agent_name || '—' %></td>
        <td style="padding:0 8px;max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;"><%= r.comments || '—' %></td>
      </tr>
    <% }); %>
  </tbody>
</table>
</div>
