// ─────────────────────────────────────────────────────────────────────────────
// SECTION 9 — COMPLAINTS AND TRASHED ITEMS
//
// COMPLAINTS:
// Attached to the order record for full context.
// Also visible in standalone complaints dashboard.
// Logged by CSR when customer calls or messages via WhatsApp.
// Resolution: call or WhatsApp — worst case a refund.
// Setting wati_suppressed = true on the order prevents sequence trigger.
// Complaints do NOT affect agent ratings.
// Abandoned orders DO affect agent ratings.
//
// TRASHED ITEMS:
// Logged by Warehouse Coordinator when failed delivery returns from agent.
// Good condition → redistributed by agent (not logged here)
// Bad condition  → agent returns physical item → logged as Trashed
//
// 📊 WEEKLY REPORT USAGE:
//   Section 3  — Individual CSR Breakdowns: customer complaints pulled per CSR per period
//   Section 5  — Returns and Complaints Analysis: complaints grouped by product and
//                reason_category. Count, percentage, key customer complaint text.
//                trashed_items feeds the returns count and physical damage reasons.
// ─────────────────────────────────────────────────────────────────────────────

Table complaints {
  // Attached to order for full context
  // Also visible in standalone complaints dashboard
  id integer [primary key, increment]
  order_id integer [not null]
  customer_id integer [not null]
  assigned_csr_id integer [note: 'CSR who logged the complaint']
  complaint_type varchar(100) [note: 'Wrong Product, Late Delivery, Damaged Item, Other']
  description text [not null]
  resolution text [note: 'How it was resolved']
  refund_amount decimal(12,2) [default: 0, note: 'Amount refunded if applicable']
  date_of_complaint date
  replaced_or_refunded boolean [default: false]
  cost_of_return decimal(12,2) [default: 0]
  total_cost decimal(12,2) [note: 'cost_of_return + refund_amount']
  date_of_return date
  status varchar(50) [default: 'Open', note: 'Open, Resolved, Escalated']
  logged_at timestamp [default: `now()`]
  resolved_at timestamp
  resolved_by integer [note: 'user_id of CSR or Director who resolved']
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
}

Table trashed_items {
  // Logged by Warehouse Coordinator when returned stock is confirmed damaged
  // Good condition returns are redistributed by agent — not logged here
  //
  // ⚠ APPLICATION LOGIC REQUIRED:
  // When a record is inserted into trashed_items, the application must
  // subtract that quantity from waybill_stock in the inventory table.
  // This prevents ghost stock — items that are trashed but still show
  // as Available because waybill_stock was never reduced.
  // Recommended: implement as a PostgreSQL trigger on trashed_items INSERT.
  id integer [primary key, increment]
  product_id integer [not null]
  variant_id integer
  quantity integer [not null]
  agent_id integer [not null, note: 'Agent who returned the item']
  admin_level_1_id integer [note: 'State the item was returned from']
  status varchar(50) [not null, default: 'Trashed', note: 'Trashed, Redistributed']
  month varchar(20)
  year integer
  comments text
  logged_by integer [not null, note: 'Warehouse Coordinator user_id']
  logged_at date [not null]
  created_at timestamp [default: `now()`]
}

// Refs — Section 9
Ref: complaints.order_id > orders.id
Ref: complaints.customer_id > customers.id
Ref: complaints.assigned_csr_id > users.id
Ref: complaints.resolved_by > users.id
Ref: trashed_items.product_id > products.id
Ref: trashed_items.variant_id > product_variants.id
Ref: trashed_items.agent_id > agents.id
Ref: trashed_items.admin_level_1_id > admin_level_1.id
Ref: trashed_items.logged_by > users.id


// ─────────────────────────────────────────────────────────────────────────────
// SECTION 10 — NOTIFICATIONS AND ALERTS
//
// INTERNAL ALERTS (CSR dashboard pills):
//   - Orders missing logistics fees
//   - Cash Paid orders with no date_paid logged
//   - Orders on Pending for more than 24 hours
//   - Orders on Interested for more than 48 hours
//
// EXTERNAL NOTIFICATIONS:
//   - Daily hygiene email to CSR at 8am — Ops Manager and Director CC'd
//   - Login alert at 9am Mon-Sat if CSR has not logged in
//   - Agent daily summary at 5am WAT — email + WATI simultaneously
//     Skip agent if zero pending/abandoned orders
//   - Abandoned order instant notification to agent when order auto-abandons
// ─────────────────────────────────────────────────────────────────────────────

Table notifications {
  // Log of every notification sent by the system
  id integer [primary key, increment]
  notification_type varchar(100) [not null, note: 'csr_alert, login_alert, agent_summary, daily_hygiene, abandoned_instant']
  channel varchar(50) [not null, note: 'email, whatsapp, internal']
  recipient_type varchar(50) [not null, note: 'user, agent']
  recipient_user_id integer [note: 'If sent to a staff member']
  recipient_agent_id integer [note: 'If sent to an agent']
  subject varchar(200)
  message text
  status varchar(50) [default: 'Sent', note: 'Sent, Failed, Pending']
  sent_at timestamp [default: `now()`]
  error_message text [note: 'If status is Failed, reason stored here']
}

// Refs — Section 10
Ref: notifications.recipient_user_id > users.id
Ref: notifications.recipient_agent_id > agents.id


// ─────────────────────────────────────────────────────────────────────────────
// SECTION 11 — WAYBILL EXPENSES
//
// Tracks inter-state shipping costs.
// Separate from regular logistics fees paid to agents.
// Waybill = goods shipped between states via third party courier.
//
// Types: Sending (Jamisan → agent) / Receiving (agent → Jamisan)
// ─────────────────────────────────────────────────────────────────────────────

Table waybill_expenses {
  id integer [primary key, increment]
  waybill_type varchar(50) [not null, note: 'Sending, Receiving']
  // 📊 WEEKLY REPORT USAGE:
  //   Section 4 — Inventory and Stock Movement: waybill movements for the period.
  //   Section 7 — Financial Summary: waybill costs feed total expenses calculation.
  //   Also triggers agent_ledger entry (Waybill_Paid_By_Agent credit) if agent paid.
  product_id integer
  variant_id integer
  quantity integer
  batch varchar(100)
  colour varchar(100)
  waybill_status varchar(50) [note: 'Warehouse, Signed Receipt, In Transit']
  product_type varchar(20) [note: 'Main or Order Bump']
  from_admin_level_1_id integer [note: 'State goods shipped from']
  to_admin_level_1_id integer [note: 'State goods shipped to']
  agent_id integer [note: 'Agent involved in the waybill']
  amount decimal(14,2) [not null, note: 'Cost of the waybill']
  currency_code varchar(10) [default: 'NGN']
  courier varchar(100) [note: 'Courier company used']
  waybill_date date [not null]
  payment_method varchar(100) [note: 'Company paid, Agent to Pay and Deduct, Petty Cash']
  month varchar(20)
  year integer
  comments text
  receipt_url varchar(500) [note: 'Google Drive link to waybill receipt or transport invoice']
  logged_by integer [not null]
  created_at timestamp [default: `now()`]
}

// Refs — Section 11
Ref: waybill_expenses.product_id > products.id
Ref: waybill_expenses.variant_id > product_variants.id
Ref: waybill_expenses.from_admin_level_1_id > admin_level_1.id
Ref: waybill_expenses.to_admin_level_1_id > admin_level_1.id
Ref: waybill_expenses.agent_id > agents.id
Ref: waybill_expenses.logged_by > users.id


// ─────────────────────────────────────────────────────────────────────────────
// SECTION 12 — ACTION ITEMS
//
// Tracks open and closed action items across the business.
// Accessible by all staff.
// Directors and Ops Manager can assign to any user.
// ─────────────────────────────────────────────────────────────────────────────

Table action_items {
  id integer [primary key, increment]
  title varchar(200) [not null]
  description text
  assigned_to integer [note: 'user_id of staff member responsible']
  assigned_by integer [note: 'user_id of Director or Ops Manager who created it']
  status varchar(50) [default: 'Open', note: 'Open, In Progress, Closed']
  priority varchar(50) [default: 'Medium', note: 'Low, Medium, High, Critical']
  due_date date
  closed_at timestamp
  closed_by integer
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
}

// Refs — Section 12
Ref: action_items.assigned_to > users.id
Ref: action_items.assigned_by > users.id
Ref: action_items.closed_by > users.id


// ─────────────────────────────────────────────────────────────────────────────
// SECTION 13 — CSR PERFORMANCE AND COMMISSION SYSTEM
//
// 5-level CSR system. Level determines base salary only.
// Commission is tiered based on monthly payment rate (units basis).
// Payment rate = paid units delivered ÷ total units ordered.
//
// Commission is retroactive — crossing a tier threshold recalculates
// ALL units sold that month at the new rate (backdating principle).
//
// Thresholds differ by department:
//   Beauty/Skincare — higher thresholds
//   Gadgets         — 5 percentage points lower (higher price point)
//
// Level promotion: 3 consecutive months above threshold
// Level demotion:  2 consecutive months below threshold
// Nigerian grace provisions apply to demotion assessments.
// ─────────────────────────────────────────────────────────────────────────────

Table csr_levels {
  // Reference table — 5 CSR levels and their base salaries
  id integer [primary key, increment]
  level_number integer [not null, note: '1 through 5']
  level_name varchar(50) [not null, note: 'Level 1, Level 2 etc']
  base_salary decimal(12,2) [not null, note: 'L1=100k L2=150k L3=180k L4=220k L5=270k']
  description text
  is_active boolean [default: true]
}

Table commission_tiers {
  // Tiered commission rates per department
  // Applied retroactively to all units sold that month when tier is crossed
  id integer [primary key, increment]
  department_id integer [not null]
  payment_rate_min decimal(5,2) [not null, note: 'Lower bound e.g. 40.00']
  payment_rate_max decimal(5,2) [note: 'Upper bound — null means no ceiling']
  commission_per_unit decimal(10,2) [not null, note: 'Naira per paid unit']
  is_active boolean [default: true]
  notes text [note: 'e.g. Transition period for gadgets']
}

Table csr_promotion_thresholds {
  // Promotion and demotion thresholds per level per department
  id integer [primary key, increment]
  department_id integer [not null]
  from_level integer [not null, note: 'Current level']
  to_level integer [not null, note: 'Target level']
  direction varchar(10) [not null, note: 'promotion or demotion']
  payment_rate_threshold decimal(5,2) [not null]
  consecutive_months_required integer [not null, note: '3 for promotion, 2 for demotion']
  is_active boolean [default: true]
}

Table csr_level_history {
  // Every level change per CSR — audit trail and historical reporting
  id integer [primary key, increment]
  user_id integer [not null]
  previous_level integer
  new_level integer [not null]
  changed_at timestamp [default: `now()`]
  changed_by integer [note: 'Director or Ops Manager user_id for manual changes. NULL for automated promotions triggered by csr_promotion_thresholds.']
  reason text [note: 'Grace provision applied, sustained performance etc']
}

Table csr_performance_monthly {
  // Monthly snapshot per CSR — source of truth for commission calculation
  // Rolling 7-day rate is calculated live from orders — not stored here
  //
  // 📊 WEEKLY REPORT USAGE:
  //   Section 2 — CSR Performance Table: payment_rate feeds benchmark status column.
  //   Section 7 — Financial Summary: commission_amount feeds payroll expense calculation.
  //   Note: The weekly report queries orders directly for the period conversion rate.
  //         csr_performance_monthly is used for the monthly commission and payroll view.
  id integer [primary key, increment]
  user_id integer [not null]
  department_id integer [not null]
  month varchar(20) [not null]
  year integer [not null]
  total_orders integer [default: 0]
  total_units_ordered integer [default: 0]
  total_units_paid integer [default: 0, note: 'Cash Paid orders only']
  payment_rate decimal(5,2) [default: 0, note: 'total_units_paid / total_units_ordered * 100']
  commission_tier_id integer [note: 'Which tier applied this month']
  commission_per_unit decimal(10,2) [default: 0]
  total_commission decimal(12,2) [default: 0]
  base_salary decimal(12,2) [default: 0]
  total_compensation decimal(12,2) [default: 0, note: 'base_salary + total_commission']
  csr_level_at_time integer [note: 'Level CSR was at during this month']
  is_finalised boolean [default: false, note: 'Locked once payroll is processed']
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
}

Table weekly_bonus_log {
  // Weekly bonus — only paid if CSR crossed 40% payment rate that week
  // Announced publicly before payment
  id integer [primary key, increment]
  user_id integer [not null]
  week_start_date date [not null]
  week_end_date date [not null]
  payment_rate_achieved decimal(5,2) [not null]
  bonus_amount decimal(10,2) [not null, default: 10000]
  qualified boolean [not null, note: 'False if nobody crossed 40% that week']
  announced_at timestamp
  paid_at timestamp
  paid_by integer [note: 'Ops Manager user_id']
  notes text
  created_at timestamp [default: `now()`]
}

// Refs — Section 13
Ref: commission_tiers.department_id > departments.id
Ref: csr_promotion_thresholds.department_id > departments.id
Ref: csr_level_history.user_id > users.id
Ref: csr_level_history.changed_by > users.id
Ref: csr_performance_monthly.user_id > users.id
Ref: csr_performance_monthly.department_id > departments.id
Ref: csr_performance_monthly.commission_tier_id > commission_tiers.id
Ref: weekly_bonus_log.user_id > users.id
Ref: weekly_bonus_log.paid_by > users.id


// ─────────────────────────────────────────────────────────────────────────────
// SECTION 14 — FRAUD PREVENTION AND SYSTEM INTEGRITY
//
// failure_reason_codes: Mandatory on Failed/Cancelled/Returned orders.
//   CSR cannot leave blank — enforced at application level.
//
// pabbly_reconciliation_log: Daily CRM vs Pabbly order count comparison.
//   Discrepancy triggers alert to Ops Manager and Director.
//
// backup_log: Tracks every pg_dump backup — local VPS and offsite Drive.
//   Director sees backup status in CRM admin panel.
//   Failed backup triggers email alert to Director.
//
// 📊 WEEKLY REPORT USAGE:
//   Section 3 — Individual CSR Breakdowns: failure_reason_codes grouped per CSR
//               for the period. Shows why orders failed — feeds the "Failed Delivery
//               reasons" section that was previously typed manually by the CSR.
//   Section 5 — Returns and Complaints Analysis: failure_reason_codes grouped by
//               product and reason category with count and percentage.
// ─────────────────────────────────────────────────────────────────────────────

Table failure_reason_codes {
  // Mandatory when order status = Failed, Cancelled, or Returned
  id integer [primary key, increment]
  code varchar(50) [not null, unique]
  description varchar(200) [not null, note: 'e.g. Customer Refused, Wrong Address, Unreachable']
  applies_to_status varchar(100) [note: 'Failed, Cancelled, Returned etc']
  is_active boolean [default: true]
}

Table pabbly_reconciliation_log {
  // Daily auto-reconciliation — CRM order count vs Pabbly webhook log
  id integer [primary key, increment]
  reconciliation_date date [not null]
  crm_order_count integer [not null]
  pabbly_order_count integer [not null]
  discrepancy integer [not null, note: 'crm_order_count - pabbly_order_count']
  status varchar(50) [not null, note: 'Matched, Discrepancy Found']
  alert_sent boolean [default: false]
  reviewed_by integer [note: 'Ops Manager or Director who reviewed']
  reviewed_at timestamp
  notes text
  created_at timestamp [default: `now()`]
}

Table backup_log {
  // Every database backup — local VPS and offsite Google Drive
  id integer [primary key, increment]
  backup_type varchar(50) [not null, note: 'local, offsite']
  file_name varchar(200)
  file_size_mb decimal(8,2)
  status varchar(50) [not null, note: 'Success, Failed, In Progress']
  started_at timestamp [not null]
  completed_at timestamp
  error_message text
  created_at timestamp [default: `now()`]
}

// Refs — Section 14
Ref: pabbly_reconciliation_log.reviewed_by > users.id


// ─────────────────────────────────────────────────────────────────────────────
// SECTION 15 — WATI INTEGRATION TRACKING
//
// V1: WATI triggered via two Google Sheets that Pabbly reads once daily
//   Sheet 1: Cash Paid Orders — triggers post-purchase sequence
//   Sheet 2: Complaints/Refunds — suppresses sequence for affected orders
//
// V2: Direct WATI API — fires immediately on Cash Paid status change
//
// Sequences are department-aware:
//   Beauty → Beauty post-purchase sequence
//   Gadgets → Gadgets post-purchase sequence
//
// Pre-purchase sequence fires for ALL customers on form submit via Pabbly.
// Cash Paid moves customer from pre-purchase to post-purchase sequence.
// Cash Remitted does NOT trigger any WATI sequence.
// Banned customers remain in sequences — no suppression.
// Unsubscribed customers (wati_opted_out) are excluded until new order.
// ─────────────────────────────────────────────────────────────────────────────

Table wati_export_log {
  // Tracks every export to Cash Paid Orders and Complaints/Refunds sheets
  // Pabbly reads these sheets once daily
  id integer [primary key, increment]
  export_type varchar(50) [not null, note: 'cash_paid_orders, complaints_refunds']
  export_date date [not null]
  records_exported integer [not null]
  status varchar(50) [not null, note: 'Success, Failed']
  error_message text
  created_at timestamp [default: `now()`]
}


// ─────────────────────────────────────────────────────────────────────────────
// SECTION 16 — STOCK ADJUSTMENTS
//
// Handles inventory shrinkage, surplus, and corrections.
// This is the "pressure valve" that aligns digital stock with physical reality.
//
// Adjustment types:
//   Shrinkage/Missing      = items lost, stolen, or unaccounted for
//   Damaged_In_Warehouse   = items damaged before dispatch
//   Marketing_Sample       = items taken as samples by Directors
//   Found/Surplus          = stocktake found more than system shows
//   Initial_Count_Correction = historical balancing entries (migration)
//
// TRIGGER LOGIC:
//   AFTER INSERT on stock_adjustments:
//   UPDATE inventory SET waybill_stock = waybill_stock + NEW.quantity_adjusted
//   WHERE product_id = NEW.product_id AND variant_id = NEW.variant_id
//
// CONSTRAINT:
//   If adjustment causes available stock to drop below zero:
//   - Warn the user and require Director approval before proceeding
//   - approved_by field must be populated before trigger fires
//
// MIGRATION NOTE:
//   All negative quantity rows in the waybill tab import here
//   with adjustment_type = 'Initial_Count_Correction'.
//   Original comments are preserved. Individual records maintained
//   for full historical audit trail.
//
// PERMISSIONS:
//   Warehouse Coordinator, Ops Manager, Directors can log adjustments.
//   Only Directors can approve adjustments that push available below zero.
// ─────────────────────────────────────────────────────────────────────────────

Table stock_adjustments {
  id integer [primary key, increment]
  product_id integer [not null]
  variant_id integer
  quantity_adjusted integer [not null, note: 'Positive = surplus found. Negative = shrinkage/loss.']
  adjustment_type varchar(100) [not null, note: 'Shrinkage/Missing, Damaged_In_Warehouse, Marketing_Sample, Found/Surplus, Initial_Count_Correction']
  comments text [not null, note: 'Mandatory — must explain reason for adjustment']
  logged_by integer [not null, note: 'Warehouse Coordinator, Ops Manager, or Director']
  approved_by integer [note: 'Director approval required if adjustment pushes available below zero']
  approved_at timestamp
  created_at timestamp [default: `now()`]
}

// Refs — Section 16
Ref: stock_adjustments.product_id > products.id
Ref: stock_adjustments.variant_id > product_variants.id
Ref: stock_adjustments.logged_by > users.id
Ref: stock_adjustments.approved_by > users.id


// ─────────────────────────────────────────────────────────────────────────────
// SECTION 17 — AGENT LEDGER
//
// Real-time chronological bank statement per agent.
// Every operational action in the CRM automatically posts an entry.
// No manual data entry required — the ledger is driven by system triggers.
//
// TRANSACTION TYPES:
//   Order_Delivered        = CSR sets order to Cash Paid → DEBIT orders.price
//   Logistics_Fee_Retained = CSR logs logistics_fee → CREDIT logistics_fee
//   Waybill_Paid_By_Agent  = Accountant logs waybill (agent paid) → CREDIT amount
//   Return_Fee_Retained    = Agent retains fee for a return → CREDIT amount
//   Cash_Remitted          = AFTER UPDATE on agent_remittance WHERE NEW.status = 'Verified_Cleared'
//                            → CREDIT final_amount_remitted (not on INSERT — must be bank-verified first)
//                            → If variance_amount is negative (shortage): the shortage amount
//                              REMAINS as a debit on the agent_ledger — it is NOT automatically forgiven.
//                              Director must explicitly log a Manual_Adjustment to forgive the shortage.
//                              This keeps the agent accountable for the missing cash.
//   Manual_Adjustment      = Director correction with mandatory reason
//
// RUNNING BALANCE:
//   Calculated by PostgreSQL trigger on every INSERT.
//   running_balance = previous_balance + debit_amount - credit_amount
//   Positive balance = agent owes Jamisan cash
//   Zero balance = agent is fully settled
//
// UI — DAILY SUMMARY WITH EXPANDABLE ROWS:
//   Default view shows one row per day per agent.
//   Each day row shows: orders delivered, logistics deducted,
//   waybills, remittance, daily net movement, running balance.
//   Clicking a day row expands to show individual transactions.
//
// DAYS OUTSTANDING CALCULATION:
//   days_outstanding = today - MAX(created_at WHERE transaction_type = 'Cash_Remitted')
//   If agent has never remitted: today - date of first delivery
//   If running_balance = 0: show as Settled regardless of last remittance date
//
// WIDGET ON OPS/FINANCE DASHBOARD:
//   Grand total: Total Cash Floating with Agents = SUM of all positive balances
//   Table of all agents with: name, state, balance, days outstanding, colour status
//   Colour coding: Red = 7+ days, Yellow = 3-6 days, Green = 0-2 days, Grey = Settled
//   Filters: by state, by colour status, by days outstanding range
//   Clicking agent row opens their full ledger statement
// ─────────────────────────────────────────────────────────────────────────────

Table agent_ledger {
  id integer [primary key, increment]
  agent_id integer [not null]
  // 📊 WEEKLY REPORT USAGE:
  //   Section 6 — Agent Performance: current running_balance and days outstanding
  //               per agent. Colour coded Red/Yellow/Green/Grey.
  //   Section 8 — Remittance Report: outstanding balance = SUM of positive
  //               running_balance across all agents as at end of period.
  //               Individual agent balances listed with days outstanding.
  transaction_type varchar(100) [not null, note: 'Order_Delivered, Logistics_Fee_Retained, Waybill_Paid_By_Agent, Return_Fee_Retained, Cash_Remitted, Manual_Adjustment']
  reference_id integer [note: 'order_id, waybill_id, or remittance_id — links to source record']
  reference_table varchar(100) [note: 'orders, waybill_expenses, or agent_remittance — identifies which table reference_id points to']
  debit_amount decimal(14,2) [default: 0, note: 'Cash agent owes Jamisan']
  credit_amount decimal(14,2) [default: 0, note: 'Cash Jamisan owes agent OR cash agent remitted']
  running_balance decimal(14,2) [not null, note: 'Calculated by trigger: previous_balance + debit_amount - credit_amount']
  currency_code varchar(10) [default: 'NGN']
  notes text [note: 'Auto-populated from source record. Manual entries require explicit reason.']
  logged_by integer [note: 'System for auto-entries. Director user_id for manual adjustments.']
  created_at timestamp [default: `now()`]
}

// Refs — Section 17
Ref: agent_ledger.agent_id > agents.id
Ref: agent_ledger.logged_by > users.id


// ─────────────────────────────────────────────────────────────────────────────
// SECTION 18 — DEPARTMENT TARGETS
//
// Configurable performance targets per department.
// Used by the CSR weekly report screen and Director dashboard.
//
// base_conversion_rate:
//   The minimum acceptable conversion rate for this department.
//   CSR report flags performance below this rate.
//   Example: Gadgets = 35%, Beauty = 43%
//
// target_conversion_rate:
//   The aspirational conversion rate — what a strong performer achieves.
//   Used for Planned Sales calculation on CSR weekly report.
//   Example: Gadgets = 40%, Beauty = 50%
//
// planned_sales_rate:
//   The rate used to calculate Planned Sales on the weekly report.
//   Currently hardcoded at 70% in Google Sheets. Now configurable per department.
//   Example: Beauty = 70%, Gadgets = 65%
//
// Only Directors can update these targets.
// Changes are logged in the audit trail.
// Effective from the date set — historical reports use the rate
// that was active at the time of the report period.
//
// 📊 WEEKLY REPORT USAGE:
//   Section 1 — Team Performance Summary: benchmark and target_conversion_rate
//               used to determine Above/Below status per CSR.
//   Section 2 — CSR Performance Table: benchmark column value comes from
//               base_conversion_rate. Target Sales column = orders x target_conversion_rate.
//   Section 3 — Individual CSR Breakdowns: Planned Sales = orders x planned_sales_rate.
//               Conversion rate flagged if below base_conversion_rate.
// Query: SELECT WHERE department_id = X AND effective_from <= period_end
//        ORDER BY effective_from DESC LIMIT 1  (gets the rate active at that time)
// ─────────────────────────────────────────────────────────────────────────────

Table department_targets {
  id integer [primary key, increment]
  department_id integer [not null, note: 'NOT unique — multiple rows per department allowed for historical tracking. Query uses effective_from to get the active rate at any point in time.']
  base_conversion_rate decimal(5,2) [not null, note: 'Minimum acceptable rate e.g. 35.00 for Gadgets']
  target_conversion_rate decimal(5,2) [not null, note: 'Strong performer rate e.g. 40.00 for Gadgets']
  planned_sales_rate decimal(5,2) [not null, default: 70.00, note: 'Used for Planned Sales calc on CSR report. Was hardcoded 70% in Google Sheets.']
  effective_from date [not null, note: 'When this target set came into effect']
  set_by integer [not null, note: 'Director who set the targets']
  notes text [note: 'Reason for target change if applicable']
  is_active boolean [default: true]
  created_at timestamp [default: `now()`]
}

// Refs — Section 18
Ref: department_targets.department_id > departments.id
Ref: department_targets.set_by > users.id


// ─────────────────────────────────────────────────────────────────────────────
// SECTION 19 — VENDORS
//
// Tracks all third-party suppliers and service providers that support operations.
// Separate from agents (who handle last-mile delivery).
// Vendors supply goods, materials, or logistics services to Jamisan directly.
//
// Examples of vendor types:
//   Shipping Agent       — international freight forwarder (Alibaba shipments)
//   Warehouse Agent      — storage and handling provider
//   Packaging Supplier   — supplies packing sacks
//   Print Supplier       — supplies printed courier bags
//
// Permissions: Ops Manager and Directors can add/edit vendors.
// ─────────────────────────────────────────────────────────────────────────────

Table vendors {
  id integer [primary key, increment]
  name varchar(200) [not null]
  vendor_type varchar(100) [note: 'Shipping Agent, Warehouse Agent, Packaging Supplier, Print Supplier, Other']
  phone_1 varchar(20)
  phone_2 varchar(20)
  address text
  city varchar(100)
  admin_level_1_id integer [note: 'State/Region']
  admin_level_2_id integer [note: 'LGA/District']
  country_id integer [note: 'Defaults to Nigeria']
  comments text [note: 'Describe the service this vendor provides']
  is_active boolean [default: true]
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
}

// Refs — Section 19
Ref: vendors.admin_level_1_id > admin_level_1.id
Ref: vendors.admin_level_2_id > admin_level_2.id
Ref: vendors.country_id > countries.id


// ─────────────────────────────────────────────────────────────────────────────
// SECTION 20 — LESSONS LEARNED (KNOWLEDGE BASE)
//
// Centralises tribal knowledge under strict executive oversight.
// All staff can submit and read published lessons.
// Only Directors can publish or reject submissions.
//
// PUBLISHING PIPELINE:
//   1. Staff member submits a proposed lesson (status = Pending)
//   2. Draft enters Director review queue
//   3. Director clicks Publish as Official → status = Published
//   4. Director can reject with mandatory reason → status = Rejected
//   No staff upvotes or peer approval — Director authority only.
//
// SEARCH:
//   Full-text search on title, content, and category.
//   Searchable by all staff for Published lessons.
//   Pending and Rejected visible to Director only.
//
// CATEGORIES:
//   Managed via lesson_categories lookup table.
//   Directors only can add new categories.
//   Starting categories: Sales Script, Logistics Warning,
//   CRM SOP, Fraud Prevention, Other.
// ─────────────────────────────────────────────────────────────────────────────

Table lesson_categories {
  id integer [primary key, increment]
  name varchar(100) [not null, unique, note: 'Sales Script, Logistics Warning, CRM SOP, Fraud Prevention, Other']
  is_active boolean [default: true]
  created_by integer [not null, note: 'Director user_id']
  created_at timestamp [default: `now()`]
}

Table lessons_learned {
  id integer [primary key, increment]
  title varchar(300) [not null]
  content text [not null, note: 'Rich text — sales scripts, SOPs, warnings, tactics']
  category_id integer [not null]
  submitted_by integer [not null, note: 'Any staff member — user_id']
  status varchar(50) [not null, default: 'Pending', note: 'Pending, Published, Rejected']
  rejection_reason text [note: 'Director must provide reason if rejecting']
  reviewed_by integer [note: 'Director user_id']
  reviewed_at timestamp
  published_at timestamp
  is_active boolean [default: true]
  created_at timestamp [default: `now()`]
  updated_at timestamp [default: `now()`]
}

// Refs — Section 20
Ref: lesson_categories.created_by > users.id
Ref: lessons_learned.category_id > lesson_categories.id
Ref: lessons_learned.submitted_by > users.id
Ref: lessons_learned.reviewed_by > users.id


// ─────────────────────────────────────────────────────────────────────────────
// SECTION 21 — HR MODULE ADDITIONS
//
// The core HR data is already covered by:
//   users, roles, employee_profiles, session_log, payroll, audit_log
//
// This section adds last_active_at to session_log to support idle
// time tracking for the digital punch-clock HR staff report.
//
// HR STAFF REPORT — ACCESS:
//   Visible to HR, Directors, and Ops Manager only.
//   Not visible to the employee themselves.
//
// HR STAFF REPORT — DATA SOURCES:
//   Login timestamps   → session_log.logged_in_at
//   Logout timestamps  → session_log.logged_out_at
//   Idle time          → session_log.last_active_at (new field — see note)
//   Daily order volume → COUNT(orders) WHERE csr_id = X AND DATE = today
//   Audit activity     → COUNT(audit_log) WHERE user_id = X AND DATE = today
//
// NOTE FOR CLAUDE CODE — MODULE 1:
//   Add last_active_at timestamp to session_log table.
//   Application updates this field on every API request from the user.
//   Idle time = last_active_at - login_at (minus active periods).
//
// ONBOARDING:
//   Director creates user account → credentials auto-generated
//   Username format: firstname.lastinitial (e.g. foluke.a)
//   Temporary password sent to employee email
//
// OFFBOARDING:
//   Director sets users.is_active = false → immediate lockout
//   All active sessions invalidated instantly
//   Audit log entry created with offboarding timestamp
// ─────────────────────────────────────────────────────────────────────────────


// ─────────────────────────────────────────────────────────────────────────────
// SECTION 22 — ESCALATIONS
//
// Handles conditional escalations from CSRs to Ops Manager.
// The Escalate button is HIDDEN by default — only appears when a strict
// system rule is triggered. Prevents CSR laziness and dashboard flooding.
//
// ESCALATION TRIGGERS:
//   1. Banned Customer: System flags row red → Request Unban button appears
//      → Forces mandatory text: "Why should this user be unbanned?"
//   2. Zero Fee: CSR attempts Cash Paid with ₦0 logistics fee → auto-escalates
//   3. Flag for Ops: General escalation with mandatory reason code selection
//
// RESOLUTION:
//   Every escalation requires Ops Manager action.
//   Cannot be left open indefinitely.
//   Resolution logged with timestamp, action, and notes.
// ─────────────────────────────────────────────────────────────────────────────

Table escalation_reason_codes {
  id integer [primary key, increment]
  code varchar(100) [not null, unique]
  description varchar(200) [not null]
  is_active boolean [default: true]
  created_by integer [not null, note: 'Director user_id — Directors manage these codes']
  created_at timestamp [default: `now()`]
  // Starting seed values:
  // Banned_Customer_Unban_Request
  // Fraud_Suspected
  // Agent_Refusing_Pickup
  // Wrong_Item_Shipped
  // Zero_Fee_Approval_Request
  // Auditor_Flag (raised by Auditor — routes to Director Approvals panel)
  // Other
}

Table order_escalations {
  id integer [primary key, increment]
  order_id integer [not null]
  reason_code_id integer [not null]
  raised_by integer [not null, note: 'user_id of staff member who raised the escalation — CSR for order flags, Auditor for Auditor_Flag reason code']
  raised_at timestamp [default: `now()`]
  csr_notes text [not null, note: 'Mandatory explanation from CSR — cannot be blank']
  status varchar(50) [not null, default: 'Open', note: 'Open, Approved, Rejected, Reassigned']
  resolved_by integer [note: 'Ops Manager or Director user_id who resolved']
  resolved_at timestamp
  resolution_action varchar(100) [note: 'Unban_User, Approve_Zero_Fee, Reassign, Reject, Investigate']
  resolution_notes text [note: 'Ops Manager explanation of action taken']
  created_at timestamp [default: `now()`]
}

// Refs — Section 22
Ref: escalation_reason_codes.created_by > users.id
Ref: order_escalations.order_id > orders.id
Ref: order_escalations.reason_code_id > escalation_reason_codes.id
Ref: order_escalations.raised_by > users.id
Ref: order_escalations.resolved_by > users.id


// ─────────────────────────────────────────────────────────────────────────────
// SECTION 23 — ACCOUNTANT MODULE ADDITIONS
//
// Variance handling on remittance verification.
// When Accountant confirms actual bank deposit differs from expected amount,
// the variance is auto-routed to Financial Losses expense category.
// Ops Manager and Director are notified with agent name, expected, actual,
// shortage amount, and reason code.
//
// RECEIPT STORAGE:
//   No file upload to VPS. Accountant uploads receipt to Google Drive manually,
//   copies the shareable link, pastes into receipt_url field on the expense entry.
//   Clicking the link opens the receipt in a new tab.
//   Simple, zero infrastructure cost, works on any device.
//   Applied to: expenses, procurement_expenses, ad_expenses, waybill_expenses.
//
// FINANCIAL LOSSES CATEGORY:
//   System-reserved expense category in expense_categories table.
//   Only the automated variance routing can write to this category.
//   Not manually selectable by Accountant or any staff.
//   Ensures books balance when agent shortages occur.
// ─────────────────────────────────────────────────────────────────────────────

Table remittance_variance_reason_codes {
  id integer [primary key, increment]
  code varchar(100) [not null, unique]
  description varchar(200) [not null]
  is_active boolean [default: true]
  created_at timestamp [default: `now()`]
  // Starting seed values:
  // Agent_Shortage — agent deliberately short-paid
  // Bank_Charges — bank deducted fees from transfer
  // Partial_Payment — agreed partial remittance
  // Transfer_Error — bank processing error
  // Overpayment — agent sent more than owed
}

// Refs — Section 23
Ref: agent_remittance.variance_reason_id > remittance_variance_reason_codes.id


// ─────────────────────────────────────────────────────────────────────────────
// SECTION 24 — AUDITOR SPOT CHECKS
//
// The Auditor module pulls 50 random orders daily (Cash Paid, Rejected,
// CSR Skipped) for spot-checking. Auditor marks each as Pass or Flagged.
// Flagged orders escalate to Director with auditor notes.
//
// NOTE: This table supports the Auditor module which is still pending
// full UI/UX spec. The table structure is confirmed — category values
// are managed via auditor_check_categories lookup table (not hardcoded)
// following the same pattern as failure_reason_codes and escalation_reason_codes.
// ─────────────────────────────────────────────────────────────────────────────

Table auditor_check_categories {
  id integer [primary key, increment]
  code varchar(100) [not null, unique]
  description varchar(200) [not null]
  is_active boolean [default: true]
  created_at timestamp [default: `now()`]
  // Starting seed values:
  // Zero_Fee_Delivery
  // High_Bounce_Order
  // Rapid_Fail
  // Suspicious_Price_Change
  // Duplicate_Customer
  // CSR_Skipped_Without_Reason
}

Table auditor_spot_checks {
  id integer [primary key, increment]
  order_id integer [not null]
  auditor_id integer [not null]
  check_date date [not null, default: `CURRENT_DATE`]
  check_category_id integer [not null]
  result varchar(50) [not null, note: 'Pass, Flagged']
  auditor_notes text
  escalated_to_director boolean [default: false]
  director_reviewed_at timestamp
  created_at timestamp [default: `now()`]
}

// Refs — Section 24
Ref: auditor_spot_checks.order_id > orders.id
Ref: auditor_spot_checks.auditor_id > users.id
Ref: auditor_spot_checks.check_category_id > auditor_check_categories.id


// ─────────────────────────────────────────────────────────────────────────────
// SECTION 25 — WEEKLY REPORTS
//
// Stores generated weekly report metadata and manual text inputs.
// Prevents manual notes from vanishing when PDF is closed.
// PDF stored as Google Drive link — same pattern as expense receipts.
//
// REPORT TYPES:
//   CSR_Personal  — Section 3 only, generated by individual CSR
//   Ops_Full      — All 10 sections, generated by Ops Manager
//
// ALL 10 SECTIONS OF THE OPS_FULL REPORT:
//   Section 1  — Team Performance Summary
//                Source: orders table (conversion rate, orders, sales, sales gap vs target)
//                Uses: department_targets for benchmark and target_conversion_rate
//   Section 2  — CSR Performance Table
//                Source: orders + csr_performance_monthly
//                Per CSR: orders, sales, conversion rate, benchmark status, planned sales
//   Section 3  — Individual CSR Breakdowns (also used for CSR_Personal report)
//                Source: orders + complaints + failure_reason_codes
//                Per product per CSR: all status columns, failure reasons, complaints
//                CSR Skipped and Interested flagged red if > 0 at period end
//   Section 4  — Inventory and Stock Movement
//                Source: inventory + goods_movement + waybill_expenses + trashed_items
//                Running balance (waybill_stock, reserved, decremented, available)
//                Goods movement within the period. Waybill movements.
//   Section 5  — Returns and Complaints Analysis
//                Source: complaints + orders + failure_reason_codes
//                Complaints grouped by product, type, resolution, cost
//   Section 6  — Agent Performance
//                Source: orders + agent_ledger + agent_remittance
//                Per agent: orders, sales, pending, abandoned, balance, days outstanding
//   Section 7  — Financial Summary
//                Source: orders + expenses + procurement_expenses + ad_expenses + waybill_expenses
//                Revenue, Expenses breakdown, Profit/Loss, Net Margin %, CPO, CPS
//   Section 8  — Remittance Report
//                Source: agent_remittance + agent_ledger
//                Amount to be remitted, amount remitted, outstanding balance per agent
//   Section 9  — Cash Flow Table (manual entry by Accountant)
//                Providus Bank: inflow, outflow, comments
//                Moniepoint Bank: inflow, outflow, comments
//                Accountant Notes — mandatory free text before Generate button activates
//   Section 10 — Any Other Business (manual entry by Ops Manager)
//                Free text entered by Ops Manager before PDF generation
//
// WORKFLOW:
//   1. Accountant fills Section 9 fields (cash flow numbers + accountant_notes)
//      → Clicking Save marks cash_flow_logged = true on this record
//      → Clears Pending Actions reminder for Accountant
//   2. Ops Manager fills ops_aob (Section 10)
//   3. Generate button activates only when cash_flow_logged = true
//   4. System compiles PDF, uploads to Google Drive, stores pdf_url here
//   5. Record persists as historical archive of every generated report
// ─────────────────────────────────────────────────────────────────────────────

Table weekly_reports {
  id integer [primary key, increment]
  report_type varchar(50) [not null, note: 'CSR_Personal, Ops_Full']
  department_id integer [note: 'Department this report covers']
  csr_id integer [note: 'For CSR_Personal reports — which CSR this belongs to']
  week_start_date date [not null]
  week_end_date date [not null]

  // ── SECTION 9 — CASH FLOW (Accountant fills before generation) ──────────
  providus_inflow decimal(14,2) [note: 'Total cash received into Providus account for the week']
  providus_outflow decimal(14,2) [note: 'Total cash paid out of Providus account for the week']
  providus_comments text [note: 'Accountant narrative on Providus activity e.g. major receipts or payments']
  moniepoint_inflow decimal(14,2) [note: 'Total cash received into Moniepoint account for the week']
  moniepoint_outflow decimal(14,2) [note: 'Total cash paid out of Moniepoint account for the week']
  moniepoint_comments text [note: 'Accountant narrative on Moniepoint activity']
  accountant_notes text [note: 'Section 9 closing notes — mandatory before Generate button activates']
  cash_flow_logged boolean [default: false, note: 'Set true when Accountant saves Section 9 fields. Generate button blocked until true. Clears Pending Actions reminder.']

  // ── SECTION 10 — ANY OTHER BUSINESS (Ops Manager fills before generation) ─
  ops_aob text [note: 'Section 10 — Any Other Business entered by Ops Manager before PDF generation']

  // ── CSR PERSONAL REPORT ─────────────────────────────────────────────────
  csr_aob text [note: 'Any Other Business entered by CSR for their Section 3 personal report']

  // ── METADATA ────────────────────────────────────────────────────────────
  generated_by integer [not null, note: 'user_id of whoever clicked Generate']
  pdf_url varchar(500) [note: 'Google Drive link to archived PDF — same pattern as expense receipts']
  created_at timestamp [default: `now()`]
}

// Refs — Section 25
Ref: weekly_reports.department_id > departments.id
Ref: weekly_reports.csr_id > users.id
Ref: weekly_reports.generated_by > users.id
